{
  "name": "@a-novel/package-authentication",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-novel/platform-authentication.git"
  },
  "license": "AGPL-3.0",
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "messages"
  ],
  "scripts": {
    "build": "vite build && npm run prepack",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "generate": "pnpm generate:translations",
    "generate:translations": "npx wuchale -c",
    "preinstall": "npx only-allow pnpm",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview"
  },
  "dependencies": {
    "@wuchale/svelte": "^0.17.5",
    "@wuchale/vite-plugin": "^0.15.3",
    "esm-env": "^1.2.2",
    "wuchale": "^0.18.5"
  },
  "devDependencies": {
    "@iconify-json/grommet-icons": "^1.2.4",
    "@iconify-json/material-symbols": "^1.2.48",
    "@iconify-json/nrk": "^1.2.7",
    "@sveltejs/adapter-node": "^5.4.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@testing-library/svelte": "^5.2.9",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.1",
    "@vitest/browser": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint-plugin-svelte": "^3.13.1",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "publint": "^0.3.15",
    "sharp": "^0.34.5",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "unplugin": "^2.3.11",
    "unplugin-icons": "^22.5.0",
    "vite": "^7.2.6",
    "vitest": "^4.0.15",
    "vitest-browser-svelte": "^2.0.1"
  },
  "peerDependencies": {
    "@a-novel/nodelib-browser": "^1.1.1",
    "@a-novel/service-authentication-rest": "^2.1.2",
    "@a-novel/uikit": "^0.3.0",
    "@sveltejs/kit": "^2.49.0",
    "svelte": "^5.0.0",
    "zod": "^4.1.12"
  },
  "packageManager": "pnpm@10.24.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
