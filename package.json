{
  "name": "platform-authentication-project",
  "version": "0.1.1",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-novel/platform-authentication.git"
  },
  "license": "AGPL-3.0",
  "type": "module",
  "workspaces": [
    ".",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm build:shared && pnpm build:platform",
    "build:ci": "pnpm build:shared && pnpm i && pnpm build:platform",
    "build:docker": "bash ./scripts/build-docker.sh",
    "build:platform": "pnpm run --dir ./packages/platform build",
    "build:shared": "pnpm run --dir ./packages/shared build",
    "build:storybook": "pnpm run --dir packages/storybook build",
    "build:storybook:ci": "pnpm build && pnpm i && pnpm run --dir packages/storybook build",
    "check": "pnpm check:shared && pnpm check:platform && pnpm check:storybook",
    "check:ci": "pnpm build && pnpm i && pnpm check",
    "check:platform": "pnpm run --dir ./packages/platform check",
    "check:shared": "pnpm run --dir ./packages/shared check",
    "check:storybook": "pnpm run --dir packages/storybook check",
    "format": "prettier --write . --config prettier.config.ts",
    "generate": "bash scripts/translations.sync.sh -a=generate -p=shared -p=platform && pnpm generate:translations:dump",
    "generate:check": "bash scripts/translations.sync.sh -a=check -p=shared -p=platform",
    "generate:check:platform": "bash scripts/translations.sync.sh -a=check -p=platform",
    "generate:check:shared": "bash scripts/translations.sync.sh -a=check -p=shared",
    "generate:platform": "bash scripts/translations.sync.sh -a=generate -p=platform && pnpm generate:translations:dump",
    "generate:shared": "bash scripts/translations.sync.sh -a=generate -p=shared && pnpm generate:translations:dump",
    "generate:translations:dump": "bash scripts/dump.sh",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm build && pnpm i --ignore-scripts",
    "lint": "pnpm lint:stylecheck && pnpm lint:typecheck && pnpm lint:eslint",
    "lint:ci": "pnpm build && pnpm i && pnpm lint",
    "lint:eslint": "eslint .",
    "lint:stylecheck": "prettier --check . --config ./prettier.config.ts",
    "lint:typecheck": "pnpm lint:typecheck:base && pnpm lint:typecheck:shared && pnpm lint:typecheck:platform && pnpm lint:typecheck:storybook",
    "lint:typecheck:base": "pnpm tsc --p ./tsconfig.json --noEmit",
    "lint:typecheck:platform": "pnpm tsc --p ./packages/platform/tsconfig.json --noEmit",
    "lint:typecheck:shared": "pnpm tsc --p ./packages/shared/tsconfig.json --noEmit",
    "lint:typecheck:storybook": "pnpm tsc --p packages/storybook/tsconfig.json --noEmit",
    "publish:major": "pnpm version major --workspaces --workspaces-update=false --no-git-tag-version && git add -A && git commit -m \"$(node -p \"require('./package.json').version\")\" && git tag v$(node -p \"require('./package.json').version\") && git push && git push --tags",
    "publish:minor": "pnpm version minor --workspaces --workspaces-update=false --no-git-tag-version && git add -A && git commit -m \"$(node -p \"require('./package.json').version\")\" && git tag v$(node -p \"require('./package.json').version\") && git push && git push --tags",
    "publish:patch": "pnpm version patch --workspaces --workspaces-update=false --no-git-tag-version && git add -A && git commit -m \"$(node -p \"require('./package.json').version\")\" && git tag v$(node -p \"require('./package.json').version\") && git push && git push --tags",
    "run": "bash ./scripts/run.sh",
    "setup:env": ". ./scripts/setup-env.sh",
    "storybook": "pnpm --dir packages/storybook run storybook",
    "test": "pnpm test:shared && pnpm test:platform",
    "test:ci": "pnpm build && pnpm i && pnpm test",
    "test:platform": "pnpm --dir ./packages/platform run test",
    "test:shared": "pnpm --dir ./packages/shared run test",
    "translations:push": "bash scripts/translations.sync.sh -a=push -p=shared -p=platform",
    "translations:push:platform": "bash scripts/translations.sync.sh -a=push -p=platform",
    "translations:push:shared": "bash scripts/translations.sync.sh -a=push -p=shared",
    "translations:server": "bash scripts/translations.sh"
  },
  "devDependencies": {
    "@a-novel-kit/nodelib-config": "^1.3.22",
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^10.0.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/node": "^24.10.4",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-storybook": "^10.1.11",
    "get-port-please": "^3.2.0",
    "globals": "^17.0.0",
    "jiti": "^2.6.1",
    "prettier": "^3.7.4",
    "prettier-plugin-css-order": "^2.1.2",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-svelte": "^3.4.1",
    "typescript-eslint": "^8.51.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.16"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.9.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@a-novel/uikit",
      "esbuild",
      "msw",
      "sharp"
    ],
    "overrides": {
      "cookie@<0.7.0": ">=0.7.0",
      "lodash-es@>=4.0.0 <=4.17.22": ">=4.17.23",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3"
    }
  }
}
